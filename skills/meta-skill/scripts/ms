#!/usr/bin/env bash
# ms — Meta-Skill 快捷命令（缓存版 ⚡）
# 首次扫描约 1 秒，之后从缓存读取约 0.05 秒
# ms --refresh 强制重新扫描
set -e

# 定位 meta_skill 模块
find_meta_skill() {
    local candidates=(
        "$HOME/Desktop/dev/Claude/Meta-Skill"
        "$HOME/.claude/skills/meta-skill"
        "$HOME/.codex/skills/meta-skill"
        "$HOME/.config/opencode/skills/meta-skill"
        "$HOME/.gemini/antigravity/skills/meta-skill"
    )
    for dir in "${candidates[@]}"; do
        if [ -d "$dir/meta_skill" ] && [ -f "$dir/meta_skill/cli.py" ]; then
            echo "$dir"
            return 0
        fi
    done
    return 1
}

PYTHON_MOD=$(find_meta_skill)
if [ -z "$PYTHON_MOD" ]; then
    echo "❌ 找不到 meta_skill 模块，请确认已安装" >&2
    exit 1
fi

# 检测系统语言
detect_locale() {
    local locale="${LANG:-${LC_ALL:-${LC_MESSAGES:-}}}"
    locale="${locale%%.*}"
    case "$locale" in
        zh_CN*|zh_TW*|zh_HK*|zh_SG*) echo "zh_CN" ;;
        ja_JP*) echo "ja_JP" ;;
        ko_KR*) echo "ko_KR" ;;
        *) echo "en_US" ;;
    esac
}

if [ "$(uname)" = "Darwin" ]; then
    MAC_LOCALE=$(defaults read -g AppleLocale 2>/dev/null || echo "")
    if echo "$MAC_LOCALE" | grep -qi "^zh"; then
        DEFAULT_LOCALE="zh_CN"
    else
        DEFAULT_LOCALE=$(detect_locale)
    fi
else
    DEFAULT_LOCALE=$(detect_locale)
fi

# 解析参数
LOCALE="$DEFAULT_LOCALE"
UNIQUE="--unique"
APP=""
SEARCH=""
FORMAT="markdown"
OUTPUT=""
QUIET=""
FORCE_SCAN=""

while [ $# -gt 0 ]; do
    case "$1" in
        zh|zh_CN|zh_CN*|zh-TW|zh_TW*)
            LOCALE="zh_CN"; shift ;;
        en|en_US|en_US*|en-GB|en_GB*)
            LOCALE="en_US"; shift ;;
        ja|ja_JP|ja_JP*)
            LOCALE="ja_JP"; shift ;;
        ko|ko_KR|ko_KR*)
            LOCALE="ko_KR"; shift ;;
        json|j)
            FORMAT="json"; shift ;;
        md|markdown|m)
            FORMAT="markdown"; shift ;;
        -o|--output)
            OUTPUT="$2"; shift 2 ;;
        -q|--quiet)
            QUIET="--quiet"; shift ;;
        -a|--all)
            UNIQUE=""; shift ;;
        -r|--refresh|--scan)
            FORCE_SCAN="1"; shift ;;
        search|s|find|f|搜索|查|找)
            shift; SEARCH="$1"; shift ;;
        -h|--help|help|帮助|帮)
            echo "ms — Meta-Skill 快捷命令（缓存版 ⚡）"
            echo ""
            echo "首次扫描约 1 秒，之后从缓存读取约 0.05 秒"
            echo ""
            echo "用法: ms [选项] [参数]"
            echo ""
            echo "选项:"
            echo "  zh          中文输出（默认）"
            echo "  en          英文输出"
            echo "  json        JSON 格式输出（需 --scan）"
            echo "  search 关键词 搜索技能（支持中文）"
            echo "  -o 文件      保存到文件（需 --scan）"
            echo "  -q          静默模式"
            echo "  -a          显示所有（不去重）"
            echo "  -r/--refresh 重新扫描更新缓存"
            echo "  -h          显示帮助"
            echo ""
            echo "示例:"
            echo "  ms              显示缓存摘要（秒级响应 ⚡）"
            echo "  ms gstack       查看 GStack 技能详情"
            echo "  ms search 调试    搜索调试技能"
            echo "  ms --refresh    重新扫描更新缓存"
            exit 0 ;;
        *)
            APP="$1"; shift ;;
    esac
done

# 构建 Python 命令
cd "$PYTHON_MOD"

if [ -n "$FORCE_SCAN" ]; then
    # 强制重新扫描
    CMD="python3 -m meta_skill.cli --locale $LOCALE $UNIQUE --format $FORMAT --refresh"
    [ -n "$QUIET" ] && CMD="$CMD $QUIET"
    [ -n "$OUTPUT" ] && CMD="$CMD --output $OUTPUT"
    [ -n "$APP" ] && CMD="$CMD --app $APP"
    [ -n "$SEARCH" ] && CMD="$CMD --search \"$SEARCH\""
    eval $CMD
elif [ -n "$SEARCH" ]; then
    # 从缓存搜索（毫秒级）
    CMD="python3 -m meta_skill.cli --locale $LOCALE --search \"$SEARCH\""
    eval $CMD
elif [ -n "$APP" ]; then
    # 从缓存查看指定应用（毫秒级）
    CMD="python3 -m meta_skill.cli --locale $LOCALE --app $APP"
    eval $CMD
else
    # 默认：显示缓存摘要（毫秒级）
    python3 -m meta_skill.cli --locale $LOCALE
fi
